<h3 class=3D"auto-cursor-target" id=3D"v4APIsgRPCFileTransfersupport-Adonis=
RestController"><span>Adonis Rest Controller</span></h3>
<p class=3D"auto-cursor-target"><span>Byte array size is 4MB and configurab=
le in Adonis</span></p>
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
 <div class=3D"codeHeader panelHeader pdl hide-border-bottom" style=3D"bord=
er-bottom-width: 1px;">
  <b class=3D"code-title">Upload controller block</b><span class=3D"collaps=
e-source expand-control" style=3D"display:none;"><span class=3D"expand-cont=
rol-icon icon">&nbsp;</span><span class=3D"expand-control-text">Expand sour=
ce</span></span><span class=3D"collapse-spinner-wrapper"></span>
 </div>
 <div class=3D"codeContent panelContent pdl hide-toolbar">
  <pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"bru=
sh: java; gutter: false; collapse: true">@RequestMapping(value =3D "/files"=
, consumes =3D MediaType.APPLICATION_OCTET_STREAM_VALUE, method =3D Request=
Method.POST)
public CompletableFuture&lt;ResponseEntity&lt;String&gt;&gt; uploadFile(Htt=
pServletRequest request) {

  log.info("Upload file request received for file {}", extId);
  CompletableFuture&lt;ResponseEntity&lt;String&gt;&gt; completable =3D new=
 CompletableFuture&lt;&gt;();

  //Specialization of StreamObserver to have flow-control
  ClientResponseObserver&lt;Data,AppMessage&gt; responseObserver =3D
      new ClientResponseObserver&lt;Data, AppMessage&gt;() {
        AppMessage appMessage;
        ServletInputStream inputStream;

        /**
         * Its used to listen to onReady events
         * @param streamObserver a refinement of CallStreamObserver that al=
lows
         *                       for lower-level interaction with client ca=
lls.
         *                       Its 'outbound', client-side observer.
         */
        @Override
        public void beforeStart(ClientCallStreamObserver&lt;Data&gt; stream=
Observer) {
          streamObserver.setOnReadyHandler(() -&gt; {
            try {
              inputStream =3D request.getInputStream();
              byte[] bytes =3D new byte[BYTE_ARRAY_SIZE];
              int curSize;
              // indicates that the observer is capable of sending
              // additional messages without requiring excessive buffering =
internally.
              while (streamObserver.isReady()){
                if (!inputStream.isFinished() &amp;&amp; (curSize =3D input=
Stream.read(bytes)) &gt; 0) {
                  streamObserver.onNext(Data.newBuilder().setData(
                                                  ByteString.copyFrom(bytes=
,0,curSize))
                                              .build());
                }
                else {
                  log.debug("Data from i/p stream has been read for file up=
load {}",extId);
                  streamObserver.onCompleted();
                }
              }
            }
            catch (java.io.IOException e) {
              log.error("Error occurred while reading from input stream {}"=
,e.getMessage());
              completable.completeExceptionally(e);
            }
          });
        }

        @Override
        public void onNext(AppMessage appMessage) {
          log.info("File upload status {}", appMessage.getStatus());
          log.info("File upload message {}", appMessage.getMessage());
          this.appMessage =3D appMessage;
        }

        @Override
        public void onError(Throwable t) {
          log.error("Error occurs while uploading file {}", t.getMessage())=
;
          completable.completeExceptionally(t);
        }

        @Override
        public void onCompleted() {
          log.info("File upload completed");
          completable.complete(ResponseEntity.ok().build());
        }

      };

   log.debug("Uploading file {}",extId);
   // TODO : Set gRPC metadata like extId, before the RPC call
 &nbsp; Metadata metadata =3D new Metadata();
   HeaderClientInterceptor interceptor =3D new HeaderClientInterceptor();
 &nbsp; interceptor.setClientSideHeaders(metadata);
 &nbsp; fileServiceStub.withInterceptors(interceptor).uploadFile(responseOb=
server);
  return completable;
}</pre>
 </div>
</div>
<h3 id=3D"v4APIsgRPCFileTransfersupport-gRPCservice"><strong class=3D"code-=
title">gRPC service</strong></h3>
<div class=3D"code panel pdl" style=3D"border-width: 1px;">
 <div class=3D"codeHeader panelHeader pdl hide-border-bottom" style=3D"bord=
er-bottom-width: 1px;">
  <b class=3D"code-title">upload sample gRPC service</b><span class=3D"coll=
apse-source expand-control" style=3D"display:none;"><span class=3D"expand-c=
ontrol-icon icon">&nbsp;</span><span class=3D"expand-control-text">Expand s=
ource</span></span><span class=3D"collapse-spinner-wrapper"></span>
 </div>
 <div class=3D"codeContent panelContent pdl hide-toolbar">
  <pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"bru=
sh: java; gutter: false; collapse: true">/**
   * Implement as per your service where onNext method will write the data =
of file while onError and complete methods=20
   * send error or success response as per the operation.
   *
   */
  public StreamObserver&lt;Data&gt; uploadFile(StreamObserver&lt;AppMessage=
&gt; responseObserver) {
    return new StreamObserver&lt;Data&gt;() {
      FileOutputStream fos ;
      AppMessage.Status status =3D Status.SUCCESS;

      @Override
      public void onNext(Data data) {
        try {
          if (fos =3D=3D null) {
            fos =3D getFileOS();
          } &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;=20
          fos.write(data.getData().toByteArray());
          fos.flush();
        } catch (Exception e) {
          this.onError(e);
        }
      }

      @Override
      public void onError(Throwable throwable) {
        log.error("Failed to upload file on server {}", throwable.getMessag=
e());
        status =3D Status.ERROR;
 &nbsp; &nbsp; &nbsp; &nbsp;responseObserver.onNext(getAppMessage());
 &nbsp; &nbsp; &nbsp; &nbsp;responseObserver.onError(throwable);
      }

      @Override
      public void onCompleted() {
        closeStream(fos); &nbsp;=20
        responseObserver.onNext(getAppMessage());
 &nbsp; &nbsp; &nbsp; &nbsp;responseObserver.onCompleted();
      }

 &nbsp; &nbsp; &nbsp;private AppMessage getAppMessage() {
          status =3D Status.OK.equals(status) ? Status.OK : status;
          String message =3D Status.OK.equals(status) ? "Successfully compl=
eted file upload request" :
                           "Failed to complete file upload request";
          return AppMessage.newBuilder().setStatus(status).setMessage(messa=
ge).build();
        } &nbsp; &nbsp;=20
    };
  }</pre>
 </div>
</div>
